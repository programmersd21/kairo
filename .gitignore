# =========================
# 🔧 Build artifacts (Go)
# =========================

# Root binaries only (avoid nuking cmd/kairo)
/kairo
/kairo.exe

# Generic binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Preferred build output dir (use this going forward)
bin/
dist/

# =========================
# 📦 Go workspace / deps
# =========================

go.work
# vendor/   # uncomment if NOT committing vendor

# =========================
# 🧠 IDE / Editor junk
# =========================

.idea/
.vscode/
*.swp
*.swo

# =========================
# 🖥 OS junk
# =========================

.DS_Store
Thumbs.db

# =========================
# 🗄 Kairo runtime data
# =========================

# DB files
kairo.db
kairo.db-wal
kairo.db-shm

# Runtime dirs
logs/
data/

# Local config (user-specific)
config.toml

# tasks metdata
tasks.json
tasks.md

# =========================
# 🔐 Optional (future-proof)
# =========================

*.zip
.env
.env.*
